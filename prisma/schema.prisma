generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id    String  @id @default(auto()) @map("_id") @db.ObjectId
  name  String  @unique
  role  String  @default("GUEST")
  bio   String? 
  beats Beat[]
}

model Beat {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  title     String
  genre     String
  bpm       Int
  price     Float
  audioUrl  String
  authorId  String?   @db.ObjectId 
  author    User?     @relation(fields: [authorId], references: [id])
}